PORT=8080

# Asterisk ARI connection
ARI_HOST=127.0.0.1
ARI_PORT=8088
ARI_USER=ariuser
ARI_PASSWORD=aripass
ARI_APP=dialer
PJSIP_PREFIX=PJSIP/

# Optional webhook to receive call status updates
WEBHOOK_URL=

# Database (MySQL)
# Either provide DATABASE_URL or individual fields below.
DATABASE_URL=mysql://user:pass@host:3306/dbname

DB_HOST=host
DB_PORT=3306
DB_USER=user
DB_PASSWORD=pass
DB_NAME=freeswitch
