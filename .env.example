PORT=8080

# Asterisk ARI connection
ARI_HOST=your-asterisk-host
ARI_PORT=8088
ARI_USER=ariuser
ARI_PASSWORD=aripass
ARI_APP=dialer
PJSIP_PREFIX=PJSIP/

# Optional webhook to receive call status updates
WEBHOOK_URL=

# API key for API endpoints (leave blank to disable)
API_KEY=

# Database (MySQL)
# Either provide DATABASE_URL or individual fields below.
DATABASE_URL=mysql://user:password@host:25060/dbname?ssl-mode=REQUIRED
