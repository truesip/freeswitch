PORT=8080

# Asterisk ARI connection
ARI_HOST=your-asterisk-host
ARI_PORT=8088
ARI_USER=ariuser
ARI_PASSWORD=aripass
ARI_APP=dialer
PJSIP_PREFIX=PJSIP/

# Optional webhook to receive call status updates (ringing/answered/hangup JSON POSTs)
WEBHOOK_URL=

# Authentication
# Either set a single API_KEY or provide multiple keys in API_KEYS (comma-separated).
API_KEY=
API_KEYS=

# Admin credentials and session secret for the web UI (/login, /admin)
# CHANGE THESE IN PRODUCTION.
ADMIN_USER=admin
ADMIN_PASS=admin123
SESSION_SECRET=change_me

# Database (MySQL)
# Either provide DATABASE_URL or individual fields below.
DATABASE_URL=mysql://user:password@host:25060/dbname?ssl-mode=REQUIRED
# DB_HOST=
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=

# Base URL used to build public media URLs for Asterisk (e.g. https://api.truesip.net)
PUBLIC_BASE_URL=https://your-app-domain

# Rate limiting (per-IP). Defaults are 60000 ms window and 60 reqs if unset.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
